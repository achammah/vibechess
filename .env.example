# ── vibechess environment ─────────────────────────────────────────────────────
# Copy to .env.local and fill in. All client vars MUST be prefixed VITE_.
# The app runs WITHOUT these (anonymous, IndexedDB-only). Add them to enable
# accounts + cloud sync.

# Clerk (auth) — Dashboard → API Keys → Publishable key (pk_test_... / pk_live_...)
VITE_CLERK_PUBLISHABLE_KEY=

# Supabase (data) — Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
