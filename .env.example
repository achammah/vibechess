# ── vibechess environment ─────────────────────────────────────────────────────
# Copy to .env.local and fill in. All client vars MUST be prefixed VITE_.
# The app runs WITHOUT these (anonymous, IndexedDB-only). Add them to enable
# accounts + cloud sync.

# Clerk (auth) — Dashboard → API Keys → Publishable key (pk_test_... / pk_live_...)
VITE_CLERK_PUBLISHABLE_KEY=

# Supabase (data) — Project Settings → API
VITE_SUPABASE_URL=
# New-format publishable key (sb_publishable_…) or legacy anon JWT:
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only (ingestion / migrations) — NEVER prefix with VITE_:
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ACCESS_TOKEN=    # personal access token, for running migrations via the Management API
