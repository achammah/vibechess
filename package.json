{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui --coverage.enabled=true",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css}\"",
    "test:coverage": "vitest run --coverage && node -e \"const s=require('./coverage/coverage-summary.json').total; console.log('Overall Coverage:', ((s.lines.pct + s.statements.pct + s.functions.pct + s.branches.pct)/4).toFixed(2)+'%');\"",
    "test:report": "open coverage/index.html",
    "test:percentage": "node -e \"const s=require('./coverage/coverage-summary.json').total; const avg=((s.lines.pct + s.statements.pct + s.functions.pct + s.branches.pct)/4).toFixed(2); const c=avg>=80?'\\x1b[32m':'\\x1b[31m'; console.log(c+'Overall Coverage: '+avg+'%\\x1b[0m');\""
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@tailwindcss/vite": "^4.2.1",
    "chess.js": "^1.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "sonner": "^2.0.7",
    "stockfish": "^18.0.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@10xscale/eslint-modern": "^0.2.0",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/preset-react": "^7.27.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.13",
    "@tanstack/eslint-plugin-query": "^5.90.12",
    "@tanstack/react-query-devtools": "^5.90.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^61.2.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^61.0.2",
    "globals": "^16.5.0",
    "happy-dom": "^17.6.3",
    "msw": "^2.11.1",
    "prettier": "^3.5.3",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.1.12",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.15",
    "web-vitals": "^5.1.0"
  }
}
